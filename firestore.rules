rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is an admin
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'admin';
    }

    // Families collection: Read by authenticated users, write by admins only
    match /families/{familyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Members collection: Read by authenticated users, write by admins only
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // User Roles: Users can read their own role, only admins can write
    match /userRoles/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    // App Settings: Read by authenticated users, write by admins only
    match /appSettings/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
