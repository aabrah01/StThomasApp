rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is an admin
    function isAdmin() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/userRoles/$(request.auth.uid)).data.role == 'admin';
    }

    // Family photos: Read by authenticated users, write by admins only
    match /families/{familyId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() &&
                      request.resource.size < 2 * 1024 * 1024 && // 2MB max
                      request.resource.contentType.matches('image/.*');
    }

    // Member photos: Read by authenticated users, write by admins only
    match /members/{memberId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() &&
                      request.resource.size < 1 * 1024 * 1024 && // 1MB max
                      request.resource.contentType.matches('image/.*');
    }
  }
}
